   "source": [
    "  for x in range(0, 21):\n",
    "    # 假设母鸡的数量为y，y的取值范围是0到33\n",
    "    for y in range(0, 34):\n",
    "        z = 100 - x - y\n",
    "        if 5 * x + 3 * y + z // 3 == 100 and z % 3 == 0:\n",
    "            print(f'公鸡: {x}只, 母鸡: {y}只, 小鸡: {z}只')\n",
    "\n"
   ]
  }
